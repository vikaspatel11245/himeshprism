# ==========================================
#  PRISM — Environment Variables Template
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to Git.
# ==========================================

# ── Groq AI (LLM for chatbot) ─────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# ── Neon PostgreSQL (Main database) ───────────────────
# Get your URL from: https://neon.tech/dashboard
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require&channel_binding=require

# ── Neon Data API (REST fallback for Python services) ─
NEON_API_URL=https://YOUR_NEON_ENDPOINT.apirest.neon.tech/neondb/rest/v1
